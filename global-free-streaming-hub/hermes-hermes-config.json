{
  "hermes": {
    "agent": {
      "name": "GlobalFreeStreamingHubAgent",
      "version": "1.0.0",
      "description": "Hermes Agent configuration with freellmapi integration",
      "capabilities": [
        "content_discovery",
        "ai_recommendations",
        "user_personalization",
        "content_curation"
      ]
    },
    "api": {
      "baseUrl": "http://localhost:3001",
      "endpoints": {
        "health": "/health",
        "hermesStatus": "/hermes/status",
        "sendCommand": "/hermes/command",
        "searchContent": "/content/search",
        "aiRecommendations": "/ai/recommend"
      }
    },
    "features": {
      "content_discovery": {
        "enabled": true,
        "sources": [
          "global_content_library",
          "user_preferences",
          "trending_content"
        ]
      },
      "ai_recommendations": {
        "enabled": true,
        "algorithms": [
          "neural_network",
          "collaborative_filtering",
          "content_based_filtering"
        ]
      },
      "user_personalization": {
        "enabled": true,
        "features": [
          "watch_history",
          "preferences",
          "search_behavior"
        ]
      }
    }
  }
}